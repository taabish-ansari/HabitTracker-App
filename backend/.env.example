# Backend Environment Variables
# Copy this to .env.local and fill in actual values

# Supabase Configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=sb_anon_your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# JWT & Security
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# Server Configuration
NODE_ENV=development
PORT=5000
ALLOW_GUEST_ACCESS=true

# Demo User (for development/guest access)
DEMO_USER_EMAIL=demo@habittracker.local
DEMO_USER_USERNAME=Demo User
DEMO_USER_PASSWORD=DemoUser123!

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Email Configuration (Optional - for password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
